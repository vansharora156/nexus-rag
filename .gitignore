<![CDATA[# =============================================================================
# AskTheCompany .gitignore
# =============================================================================

# ---------- Python ----------
__pycache__/
*.py[cod]
*$py.class
*.so

# Distribution / packaging
build/
dist/
*.egg-info/
*.egg
wheels/
pip-wheel-metadata/

# Virtual environments
.venv/
venv/
ENV/

# ---------- Environment ----------
.env
.env.local
.env.production

# ---------- IDE ----------
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# ---------- Testing ----------
.pytest_cache/
.coverage
htmlcov/
.tox/

# ---------- Type checking ----------
.mypy_cache/
.pytype/

# ---------- ChromaDB ----------
chroma_db/

# ---------- BM25 Index ----------
bm25_index/

# ---------- Generated Data ----------
# Synthetic enterprise data is generated locally, not tracked
data/pdf/*
!data/pdf/.gitkeep
data/markdown/*
!data/markdown/.gitkeep
data/excel/*
!data/excel/.gitkeep
data/slack/*
!data/slack/.gitkeep
data/sample/*
!data/sample/.gitkeep
data/generated/

# ---------- Node (if UI tooling is added) ----------
node_modules/

# ---------- Logs ----------
*.log
logs/

# ---------- Misc ----------
*.bak
*.tmp
]]>
